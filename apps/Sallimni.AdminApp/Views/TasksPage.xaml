<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.AdminApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.AdminApp.Models"
             xmlns:svc="clr-namespace:Sallimni.AdminApp.Services"
             x:Class="Sallimni.AdminApp.Views.TasksPage"
             x:Name="Page"
             x:DataType="vm:TasksViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.tasks}">

    <ScrollView>
        <VerticalStackLayout Padding="14" Spacing="12">

            <Label Text="{svc:Translate Key=tasks.title}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" FontSize="12"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNull}}" />

            <!-- الموجات -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Waves}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:WaveSummaryDto">
                        <Border Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Label FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryDark}">
                                    <Label.FormattedText><FormattedString>
                                        <Span Text="{svc:Translate Key=tasks.wave}" /><Span Text="  " />
                                        <Span Text="{Binding OrderCount}" /><Span Text=" " /><Span Text="{svc:Translate Key=tasks.orders}" />
                                        <Span Text="  ·  " />
                                        <Span Text="{Binding SubOrderCount}" /><Span Text=" " /><Span Text="{svc:Translate Key=tasks.subs}" />
                                    </FormattedString></Label.FormattedText>
                                </Label>
                                <HorizontalStackLayout Spacing="8">
                                    <Button Text="{svc:Translate Key=tasks.collection}"
                                            IsVisible="{Binding HasCollectionTask, Converter={StaticResource Invert}}"
                                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="16" Padding="14,5" FontSize="13"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.CreateCollectionCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Text="{svc:Translate Key=tasks.collectionDone}" FontSize="13" TextColor="{StaticResource Primary}" VerticalOptions="Center"
                                           IsVisible="{Binding HasCollectionTask}" />
                                    <Button Text="{svc:Translate Key=tasks.distribution}"
                                            IsVisible="{Binding HasDistributionTask, Converter={StaticResource Invert}}"
                                            BackgroundColor="{StaticResource Tertiary}" TextColor="White" CornerRadius="16" Padding="14,5" FontSize="13"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.CreateDistributionCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Text="{svc:Translate Key=tasks.distributionDone}" FontSize="13" TextColor="{StaticResource Tertiary}" VerticalOptions="Center"
                                           IsVisible="{Binding HasDistributionTask}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" Margin="0,4" />

            <!-- إسناد السائق -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="{svc:Translate Key=tasks.assign}" VerticalOptions="Center" FontSize="13" TextColor="{StaticResource Gray600}" />
                <Picker ItemsSource="{Binding Drivers}" SelectedItem="{Binding SelectedDriver}" WidthRequest="180" />
            </HorizontalStackLayout>

            <!-- المهام -->
            <Label Text="{svc:Translate Key=tasks.list}" FontAttributes="Bold" FontSize="16" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Tasks}" Spacing="8">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:TaskDto">
                        <Border Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="6">
                                <Label FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryDark}"
                                       Text="{svc:Translate Key=tasks.colltype}"
                                       IsVisible="{Binding Type, Converter={StaticResource IntEq}, ConverterParameter=0}" />
                                <Label FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryDark}"
                                       Text="{svc:Translate Key=tasks.disttype}"
                                       IsVisible="{Binding Type, Converter={StaticResource IntEq}, ConverterParameter=1}" />

                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Stops}" Spacing="2">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="m:TaskStopDto">
                                            <Label FontSize="13" TextColor="{StaticResource Gray600}">
                                                <Label.FormattedText><FormattedString>
                                                    <Span Text="{Binding Sequence}" /><Span Text=". " /><Span Text="{Binding Label}" />
                                                </FormattedString></Label.FormattedText>
                                            </Label>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Button Grid.Column="0" Text="{svc:Translate Key=tasks.assign}"
                                            IsVisible="{Binding DriverName, Converter={StaticResource IsNull}}"
                                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="16" Padding="16,5" FontSize="13"
                                            Command="{Binding Source={x:Reference Page}, Path=BindingContext.AssignCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Grid.Column="1" VerticalOptions="Center" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Primary}"
                                           Text="{Binding DriverName}" IsVisible="{Binding DriverName, Converter={StaticResource NotNull}}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
