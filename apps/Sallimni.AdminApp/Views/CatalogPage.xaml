<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.AdminApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.AdminApp.Models"
             xmlns:svc="clr-namespace:Sallimni.AdminApp.Services"
             x:Class="Sallimni.AdminApp.Views.CatalogPage"
             x:DataType="vm:CatalogViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.catalog}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="تأسيس الأصناف" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
            <Label Text="الإدارة تملك البطاقة الرئيسية للصنف وتنشئها هنا." FontSize="12" TextColor="{StaticResource Gray500}" />

            <!-- نموذج إضافة بطاقة صنف -->
            <Border Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="➕ بطاقة صنف جديدة" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryDark}" />
                    <Entry Placeholder="الاسم بالعربية *" Text="{Binding NameAr}" />
                    <Entry Placeholder="الاسم بالإنجليزية" Text="{Binding NameEn}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <Entry Grid.Column="0" Placeholder="الباركود" Text="{Binding Barcode}" Keyboard="Numeric" />
                        <Entry Grid.Column="1" Placeholder="الوحدة/الحجم (مثل 1L)" Text="{Binding UnitSize}" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <Entry Grid.Column="0" Placeholder="رمز 🛒" Text="{Binding Emoji}" WidthRequest="90" />
                        <Entry Grid.Column="1" Placeholder="الوصف" Text="{Binding Description}" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="التصنيف" FontSize="11" TextColor="{StaticResource Gray500}" />
                            <Picker ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" ItemDisplayBinding="{Binding NameAr}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2">
                            <Label Text="فئة الضريبة" FontSize="11" TextColor="{StaticResource Gray500}" />
                            <Picker ItemsSource="{Binding TaxOptions}" SelectedItem="{Binding SelectedTax}" />
                        </VerticalStackLayout>
                    </Grid>
                    <Button Text="أضف الصنف" Command="{Binding AddProductCommand}" IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" HeightRequest="46" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <!-- نموذج إضافة تصنيف -->
            <Border Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="➕ تصنيف جديد" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryDark}" />
                    <Grid ColumnDefinitions="Auto,*,*" ColumnSpacing="8">
                        <Entry Grid.Column="0" Placeholder="🥤" Text="{Binding CatIcon}" WidthRequest="70" />
                        <Entry Grid.Column="1" Placeholder="بالعربية *" Text="{Binding CatNameAr}" />
                        <Entry Grid.Column="2" Placeholder="بالإنجليزية" Text="{Binding CatNameEn}" />
                    </Grid>
                    <Button Text="أضف التصنيف" Command="{Binding AddCategoryCommand}" IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="{StaticResource Tertiary}" TextColor="White" CornerRadius="18" Padding="20,6" HorizontalOptions="Start" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding StatusMessage}" TextColor="{StaticResource Primary}" FontAttributes="Bold" IsVisible="{Binding StatusMessage, Converter={StaticResource NotNull}}" />
            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNull}}" />

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

            <!-- إدارة التصنيفات -->
            <Label Text="التصنيفات" FontAttributes="Bold" FontSize="16" />
            <FlexLayout BindableLayout.ItemsSource="{Binding Categories}" Wrap="Wrap" JustifyContent="Start">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:CategoryDto">
                        <Border Margin="0,0,8,8" Padding="10,5" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding NameAr}" FontSize="13" VerticalOptions="Center" />
                                <Label Text="✕" FontSize="13" TextColor="#D32F2F" VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CatalogViewModel}}, Path=DeleteCategoryCommand}" CommandParameter="{Binding .}" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

            <!-- قائمة الأصناف الموجودة (اضغط لتعديل) -->
            <Label Text="الأصناف الحالية — اضغط على صنف لتعديله أو حذفه" FontAttributes="Bold" FontSize="16" />
            <Label Text="لا أصناف بعد — أضِف أول صنف من الأعلى." FontSize="13" TextColor="{StaticResource Gray400}"
                   IsVisible="{Binding HasProducts, Converter={StaticResource Invert}}" />
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Products}" Spacing="6">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:AdminProductDto">
                        <Border Padding="12" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CatalogViewModel}}, Path=OpenProductCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <!-- صورة حقيقية أو رمز بديل -->
                                <Grid Grid.Column="0" WidthRequest="44" HeightRequest="44" VerticalOptions="Center">
                                    <Image Source="{Binding FullImageUrl}" Aspect="AspectFill" IsVisible="{Binding HasImage}" />
                                    <Label Text="{Binding Glyph}" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasImage, Converter={StaticResource Invert}}" />
                                </Grid>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding NameAr}" FontAttributes="Bold" FontSize="15" />
                                    <Label FontSize="11" TextColor="{StaticResource Gray500}">
                                        <Label.FormattedText><FormattedString>
                                            <Span Text="{Binding CategoryNameAr}" /><Span Text="  ·  " />
                                            <Span Text="{Binding UnitSize}" /><Span Text="  ·  ضريبة " /><Span Text="{Binding TaxClass}" /><Span Text="%" />
                                        </FormattedString></Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="✏" FontSize="18" TextColor="{StaticResource Primary}" VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
