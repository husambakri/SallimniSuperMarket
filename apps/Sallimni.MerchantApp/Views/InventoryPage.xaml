<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.MerchantApp.ViewModels"
             xmlns:svc="clr-namespace:Sallimni.MerchantApp.Services"
             x:Class="Sallimni.MerchantApp.Views.InventoryPage"
             x:DataType="vm:InventoryViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.inventory}">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,12" StrokeThickness="0">
            <Label Text="{svc:Translate Key=inv.title}" FontSize="18" FontAttributes="Bold" TextColor="White" />
        </Border>

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Rows}" Margin="10">
                <CollectionView.EmptyView>
                    <Label Text="{svc:Translate Key=common.loading}" HorizontalOptions="Center" Margin="0,40" />
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:InventoryRow">
                        <Border Margin="0,5" Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                                        <Label Text="{Binding NameAr}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                                        <Label Text="{Binding UnitSize}" FontSize="12" TextColor="{StaticResource Gray500}" />
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" Padding="8,3" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                                            BackgroundColor="{StaticResource Secondary}" VerticalOptions="Center">
                                        <Grid>
                                            <Label Text="{svc:Translate Key=inv.linked}" FontSize="11" TextColor="{StaticResource PrimaryDark}"
                                                   IsVisible="{Binding IsLinked}" />
                                            <Label Text="{svc:Translate Key=inv.notlinked}" FontSize="11" TextColor="{StaticResource Gray500}"
                                                   IsVisible="{Binding IsLinked, Converter={StaticResource Invert}}" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="8" RowDefinitions="Auto,Auto">
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                                        <Label Text="{svc:Translate Key=inv.price}" FontSize="11" TextColor="{StaticResource Gray500}" />
                                        <Entry Text="{Binding Price}" Keyboard="Numeric" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="2">
                                        <Label Text="{svc:Translate Key=inv.stock}" FontSize="11" TextColor="{StaticResource Gray500}" />
                                        <Entry Text="{Binding StockQty}" Keyboard="Numeric" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Row="0" Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{svc:Translate Key=inv.available}" FontSize="11" TextColor="{StaticResource Gray500}" />
                                        <Switch IsToggled="{Binding IsAvailable}" OnColor="{StaticResource Primary}" HorizontalOptions="Start" />
                                    </VerticalStackLayout>
                                </Grid>

                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                    <Button Grid.Column="0" Text="{svc:Translate Key=inv.save}"
                                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="18" Padding="22,6"
                                            IsEnabled="{Binding IsSaving, Converter={StaticResource Invert}}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.SaveCommand}"
                                            CommandParameter="{Binding .}" />
                                    <Label Grid.Column="1" Text="{svc:Translate Key=inv.saved}" VerticalOptions="Center"
                                           TextColor="{StaticResource Primary}" FontAttributes="Bold"
                                           IsVisible="{Binding SavedVisible}" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
