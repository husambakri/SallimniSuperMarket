<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Sallimni.MerchantApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Sallimni.MerchantApp.Views"
    xmlns:svc="clr-namespace:Sallimni.MerchantApp.Services"
    FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
    Title="سلّمني تاجر">

    <TabBar>
        <ShellContent Title="{svc:Translate Key=tab.orders}"
                      ContentTemplate="{DataTemplate views:OrdersPage}"
                      Route="orders" />
        <ShellContent Title="{svc:Translate Key=tab.inventory}"
                      ContentTemplate="{DataTemplate views:InventoryPage}"
                      Route="inventory" />
        <ShellContent Title="{svc:Translate Key=tab.submit}"
                      ContentTemplate="{DataTemplate views:SubmitPage}"
                      Route="submit" />
        <ShellContent Title="{svc:Translate Key=tab.settings}"
                      ContentTemplate="{DataTemplate views:SettingsPage}"
                      Route="settings" />
    </TabBar>
</Shell>
