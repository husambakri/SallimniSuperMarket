<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Sallimni.ValidationApp"
             x:Class="Sallimni.ValidationApp.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="Primary">#0F6E56</Color>
            <Color x:Key="PrimaryDark">#04342C</Color>
            <Color x:Key="Accent">#1D9E75</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="Gray100">#F1EFE8</Color>
            <Color x:Key="Gray200">#D3D1C7</Color>
            <Color x:Key="Gray400">#888780</Color>
            <Color x:Key="Gray500">#5F5E5A</Color>
            <Color x:Key="Gray900">#2C2C2A</Color>
            <Color x:Key="PageBg">#F5F4EF</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
