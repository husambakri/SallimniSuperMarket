<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Sallimni.ValidationApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Sallimni.ValidationApp.Views"
    FlowDirection="RightToLeft"
    Title="تحقّق الأسعار">

    <TabBar>
        <ShellContent Title="مسح"
            ContentTemplate="{DataTemplate views:ScanPage}" Route="scan" />
        <ShellContent Title="السجلّ"
            ContentTemplate="{DataTemplate views:HistoryPage}" Route="history" />
        <ShellContent Title="القاعدة"
            ContentTemplate="{DataTemplate views:InfoPage}" Route="info" />
    </TabBar>

</Shell>
