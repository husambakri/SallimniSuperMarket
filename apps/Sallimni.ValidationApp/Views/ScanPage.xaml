<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.ValidationApp.ViewModels"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="Sallimni.ValidationApp.Views.ScanPage"
             x:DataType="vm:ValidationViewModel"
             FlowDirection="RightToLeft"
             BackgroundColor="{StaticResource PageBg}"
             Title="تحقّق الأسعار">

    <Grid Padding="16,12,16,14" RowSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*">

        <!-- الترويسة -->
        <VerticalStackLayout Grid.Row="0" Spacing="1">
            <Label Text="تحقّق الأسعار" FontSize="21" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            <Label Text="اختر الفرع ثم امسح الباركود لتحقّق سعره" FontSize="12" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <!-- الفرع المختار (مثبّت في الترويسة) -->
        <Border Grid.Row="1" Stroke="{StaticResource Primary}" StrokeThickness="1.5" StrokeShape="RoundRectangle 22"
                BackgroundColor="{StaticResource Surface}" Padding="12,3">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" VerticalOptions="Center">
                <Label Grid.Column="0" Text="🏪" FontSize="17" VerticalOptions="Center" />
                <Picker Grid.Column="1" Title="اختر المتجر / الفرع…" ItemsSource="{Binding Merchants}"
                        ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedMerchant}"
                        FontSize="15.5" TextColor="{StaticResource Gray900}" TitleColor="{StaticResource Primary}"
                        BackgroundColor="Transparent" VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- اسم العامل (يُحفظ ويُرفق بكل تسجيل) -->
        <Border Grid.Row="2" Stroke="{StaticResource Gray200}" StrokeThickness="1" StrokeShape="RoundRectangle 22"
                BackgroundColor="{StaticResource Surface}" Padding="12,2">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" VerticalOptions="Center">
                <Label Grid.Column="0" Text="👤" FontSize="15" VerticalOptions="Center" />
                <Entry Grid.Column="1" Placeholder="اسم العامل (اختياري)" Text="{Binding Auditor}"
                       FontSize="14" BackgroundColor="Transparent" VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- امسح بالكاميرا (الهاتف فقط) -->
        <Button Grid.Row="3" Text="📷  امسح الباركود" Command="{Binding ToggleScanCommand}"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                CornerRadius="26" HeightRequest="50" FontSize="16" FontAttributes="Bold"
                Padding="12,0" LineBreakMode="NoWrap">
            <Button.IsVisible>
                <OnPlatform x:TypeArguments="x:Boolean">
                    <On Platform="Android,iOS" Value="True" />
                    <On Platform="WinUI" Value="False" />
                </OnPlatform>
            </Button.IsVisible>
        </Button>

        <!-- إدخال يدوي للباركود -->
        <Border Grid.Row="4" Stroke="{StaticResource Gray200}" StrokeThickness="1" StrokeShape="RoundRectangle 26"
                BackgroundColor="{StaticResource Surface}" Padding="6,5">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" VerticalOptions="Center">
                <Label Grid.Column="0" Text="🔎" FontSize="16" Margin="10,0,2,0" VerticalOptions="Center" />
                <Entry Grid.Column="1" Placeholder="أدخل الباركود يدويًا" Text="{Binding Barcode}"
                       Keyboard="Numeric" FontSize="16" BackgroundColor="Transparent" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="بحث" Command="{Binding LookupCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        CornerRadius="20" HeightRequest="40" Padding="18,0" FontAttributes="Bold" />
            </Grid>
        </Border>

        <!-- المساحة المرنة -->
        <Grid Grid.Row="5">

            <!-- تلميح -->
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="🧾" FontSize="58" HorizontalOptions="Center" Opacity="0.5" />
                <Label Text="امسح باركود المنتج لتحقّق سعره في هذا الفرع"
                       FontSize="13.5" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" MaxLines="2" />
                <Border IsVisible="{Binding HasStatus}" BackgroundColor="{StaticResource Accent}"
                        StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,7" HorizontalOptions="Center">
                    <Label Text="{Binding StatusMessage}" FontSize="13" FontAttributes="Bold" TextColor="White" />
                </Border>
            </VerticalStackLayout>

            <!-- معاينة الكاميرا -->
            <Border IsVisible="{Binding IsScanning}" HeightRequest="290" VerticalOptions="Center"
                    StrokeShape="RoundRectangle 20" StrokeThickness="2"
                    Stroke="{StaticResource Accent}" Padding="0" BackgroundColor="#101010">
                <Grid>
                    <scanner:CameraView x:Name="Reader"
                            CameraEnabled="{Binding IsScanning}"
                            VibrationOnDetected="True"
                            ViewfinderMode="True"
                            CaptureQuality="Medium"
                            BarcodeSymbologies="All"
                            OnDetectionFinished="OnDetectionFinished" />
                    <Border VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,14"
                            BackgroundColor="#CC000000" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,7">
                        <Label Text="وجّه الكاميرا نحو الباركود" FontSize="12" TextColor="White" />
                    </Border>
                </Grid>
            </Border>

            <!-- بطاقة التحقّق -->
            <ScrollView IsVisible="{Binding HasLookup}">
                <Border StrokeShape="RoundRectangle 22" StrokeThickness="1"
                        Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="18">
                    <VerticalStackLayout Spacing="14">

                        <!-- الصنف -->
                        <Label Text="{Binding ProductName}" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" HorizontalTextAlignment="Center"
                               MaxLines="2" LineBreakMode="TailTruncation" />

                        <!-- سعرنا المخزّن -->
                        <VerticalStackLayout Spacing="3" HorizontalOptions="Center" IsVisible="{Binding HasOurPrice}">
                            <Label Text="سعرنا المخزّن في هذا الفرع" FontSize="11.5" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="{Binding ExpectedPriceText}" FontSize="34" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                <Label Text="د.أ" FontSize="14" TextColor="{StaticResource Gray500}" VerticalOptions="End" Margin="0,0,0,7" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Label IsVisible="{Binding HasNoOurPrice}"
                               Text="لا سعر مخزّن لهذا الصنف في هذا الفرع — أدخل السعر الواقعي لتسجيله"
                               FontSize="12.5" TextColor="{StaticResource Gray500}" HorizontalTextAlignment="Center" />

                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                        <!-- السعر الحقيقي -->
                        <VerticalStackLayout Spacing="6">
                            <Label Text="السعر الحقيقي على الرف" FontSize="12.5" TextColor="{StaticResource Gray600}" />
                            <Border Stroke="{StaticResource Gray200}" StrokeThickness="1.5" StrokeShape="RoundRectangle 16"
                                    BackgroundColor="{StaticResource Surface}" Padding="14,2">
                                <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                                    <Entry Grid.Column="0" Text="{Binding ActualPriceInput}" Keyboard="Numeric"
                                           FontSize="22" FontAttributes="Bold" BackgroundColor="Transparent" />
                                    <Label Grid.Column="1" Text="د.أ" FontSize="14" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- تأكيد -->
                        <Button Text="✓  تأكيد OK" Command="{Binding ConfirmCommand}"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                CornerRadius="24" HeightRequest="50" FontSize="16" FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Border>
            </ScrollView>

            <!-- خطأ -->
            <Border IsVisible="{Binding HasError}" VerticalOptions="Center" StrokeShape="RoundRectangle 18" StrokeThickness="1"
                    Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="20">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="⚠️" FontSize="30" HorizontalOptions="Center" />
                    <Label Text="{Binding ErrorMessage}" FontSize="14" TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- انتظار -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}" VerticalOptions="Center" Spacing="8">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
                <Label Text="جارٍ العمل…" FontSize="13" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
