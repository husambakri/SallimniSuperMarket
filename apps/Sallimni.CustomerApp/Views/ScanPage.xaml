<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.CustomerApp.Models"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="Sallimni.CustomerApp.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.scan}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="{svc:Translate Key=scan.title}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
            <Label Text="{svc:Translate Key=scan.hint}" FontSize="13" TextColor="{StaticResource Gray500}" />

            <!-- زرّ تشغيل/إيقاف مسح الكاميرا الحيّ (الكاميرا للهاتف؛ يُخفى على Windows) -->
            <Button Text="📷 امسح بالكاميرا" Command="{Binding ToggleScanCommand}"
                    BackgroundColor="{StaticResource PrimaryDark}" TextColor="White" CornerRadius="22">
                <Button.IsVisible>
                    <OnPlatform x:TypeArguments="x:Boolean">
                        <On Platform="Android,iOS" Value="True" />
                        <On Platform="WinUI" Value="False" />
                    </OnPlatform>
                </Button.IsVisible>
            </Button>

            <!-- معاينة الكاميرا الحيّة — تظهر فقط أثناء المسح -->
            <Border IsVisible="{Binding IsScanning}" StrokeShape="RoundRectangle 16" StrokeThickness="2"
                    Stroke="{StaticResource Primary}" HeightRequest="300" Padding="0">
                <scanner:CameraView x:Name="Reader"
                        CameraEnabled="{Binding IsScanning}"
                        VibrationOnDetected="True"
                        ViewfinderMode="True"
                        CaptureQuality="Medium"
                        BarcodeSymbologies="All"
                        OnDetectionFinished="OnDetectionFinished" />
            </Border>

            <!-- إدخال يدوي بديل -->
            <Entry Placeholder="{svc:Translate Key=scan.placeholder}" Text="{Binding Barcode}"
                   Keyboard="Numeric" FontSize="16" />

            <Button Text="{svc:Translate Key=scan.button}" Command="{Binding LookupCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="22" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />

            <!-- النتيجة: موجود -> سعرنا + أضف للسلة ؛ غير موجود -> رسالة فقط -->
            <Border IsVisible="{Binding HasResult}" StrokeShape="RoundRectangle 16" Padding="18"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="10">
                    <!-- صورة المنتج (أو رمز تعبيري بديل) عند توفّر النتيجة -->
                    <Border IsVisible="{Binding Result.Found}" HeightRequest="160" WidthRequest="160"
                            HorizontalOptions="Center" StrokeThickness="0" BackgroundColor="{StaticResource Gray100}"
                            StrokeShape="RoundRectangle 14" Padding="0">
                        <Grid>
                            <Image Source="{Binding Result.FullImageUrl}" Aspect="AspectFit" Margin="8"
                                   IsVisible="{Binding Result.HasImage}" />
                            <Label Text="{Binding Result.Glyph}" FontSize="72"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   IsVisible="{Binding Result.HasImage, Converter={StaticResource Invert}}" />
                        </Grid>
                    </Border>

                    <Label Text="{Binding Result.NameAr}" FontSize="18" FontAttributes="Bold"
                           IsVisible="{Binding Result.Found}" />
                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding Result.Found}">
                        <Label Text="{svc:Translate Key=scan.ourprice}" FontSize="14" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                        <Label Text="{Binding Result.OurPriceInclTax, Converter={StaticResource Price}}"
                               FontSize="26" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="{svc:Translate Key=common.currency}" VerticalOptions="Center" TextColor="{StaticResource Gray500}" />
                    </HorizontalStackLayout>

                    <Button Text="{svc:Translate Key=catalog.add}" Command="{Binding AddResultToCartCommand}"
                            IsVisible="{Binding CanAddResult}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" />

                    <Label Text="{svc:Translate Key=scan.notfound}" FontSize="16" TextColor="{StaticResource Gray500}"
                           IsVisible="{Binding Result.Found, Converter={StaticResource Invert}}" />
                </VerticalStackLayout>
            </Border>

            <!-- مقارنة الأسعار الحيّة عبر متاجر البقالة الأردنية (تجريبي) -->
            <VerticalStackLayout IsVisible="{Binding HasResult}" Spacing="8" Margin="0,4,0,0">
                <Label Text="مقارنة الأسعار في المتاجر (تجريبي)" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
                <ActivityIndicator IsRunning="{Binding IsComparing}" IsVisible="{Binding IsComparing}" Color="{StaticResource Primary}" HeightRequest="24" />

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding CompareResults}" Spacing="0"
                                     IsVisible="{Binding HasCompared}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="m:LiveScanDto">
                            <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="10" Margin="0,0,0,8">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                    <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeThickness="0"
                                            BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 10" Padding="0">
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFit" Margin="4" IsVisible="{Binding HasImage}" />
                                            <Label Text="{Binding Glyph}" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"
                                                   IsVisible="{Binding HasImage, Converter={StaticResource Invert}}" />
                                        </Grid>
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding Store}" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource Gray900}" MaxLines="1" />
                                        <Label Text="{Binding StockStatus}" FontSize="11" TextColor="{StaticResource Gray400}" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="2" Spacing="3" VerticalOptions="Center">
                                        <Label Text="{Binding EffectivePrice, Converter={StaticResource Price}}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
                                        <Label Text="{svc:Translate Key=common.currency}" FontSize="11" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                    <BindableLayout.EmptyView>
                        <Label Text="لا نتائج حيّة من المتاجر حالياً" FontSize="13" TextColor="{StaticResource Gray400}" HorizontalOptions="Center" Margin="0,8" />
                    </BindableLayout.EmptyView>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNull}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
