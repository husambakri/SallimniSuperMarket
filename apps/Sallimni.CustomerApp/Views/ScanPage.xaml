<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
             x:Class="Sallimni.CustomerApp.Views.ScanPage"
             x:DataType="vm:ScanViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.scan}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="{svc:Translate Key=scan.title}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
            <Label Text="{svc:Translate Key=scan.hint}" FontSize="13" TextColor="{StaticResource Gray500}" />

            <!-- زرّ تشغيل/إيقاف مسح الكاميرا الحيّ -->
            <Button Text="📷 امسح بالكاميرا" Command="{Binding ToggleScanCommand}"
                    BackgroundColor="{StaticResource PrimaryDark}" TextColor="White" CornerRadius="22" />

            <!-- معاينة الكاميرا الحيّة — تظهر فقط أثناء المسح -->
            <Border IsVisible="{Binding IsScanning}" StrokeShape="RoundRectangle 16" StrokeThickness="2"
                    Stroke="{StaticResource Primary}" HeightRequest="300" Padding="0">
                <Grid>
                    <zxing:CameraBarcodeReaderView x:Name="Reader"
                            IsDetecting="{Binding IsScanning}"
                            BarcodesDetected="OnBarcodesDetected" />

                    <!-- طبقة فوق الكاميرا (لا تلمس تدفّق الإطارات): نافذة مسح + خط أحمر متوهّج.
                         العمود الأوسط 8* من 10 = عرض 80٪؛ InputTransparent يمرّر اللمس. -->
                    <Grid ColumnDefinitions="*,8*,*" RowDefinitions="*,Auto,*" InputTransparent="True">
                        <!-- إطار نافذة المسح (دليل بصري للمنتصف) -->
                        <Border Grid.Column="1" Grid.Row="1" HeightRequest="130"
                                Stroke="#80FFFFFF" StrokeThickness="1.5"
                                StrokeShape="RoundRectangle 12" BackgroundColor="Transparent"
                                InputTransparent="True" />
                        <!-- الخط الأحمر: عرض 80٪، سماكة 3، أحمر شفاف قليلاً + توهّج -->
                        <BoxView Grid.Column="1" Grid.Row="1" HeightRequest="3" CornerRadius="2"
                                 Color="#E6FF2222" HorizontalOptions="Fill" VerticalOptions="Center"
                                 InputTransparent="True">
                            <BoxView.Shadow>
                                <Shadow Brush="Red" Radius="12" Opacity="0.9" Offset="0,0" />
                            </BoxView.Shadow>
                        </BoxView>
                    </Grid>
                </Grid>
            </Border>

            <!-- إدخال يدوي بديل -->
            <Entry Placeholder="{svc:Translate Key=scan.placeholder}" Text="{Binding Barcode}"
                   Keyboard="Numeric" FontSize="16" />

            <Button Text="{svc:Translate Key=scan.button}" Command="{Binding LookupCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="22" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />

            <!-- النتيجة: موجود -> سعرنا + أضف للسلة ؛ غير موجود -> رسالة فقط -->
            <Border IsVisible="{Binding HasResult}" StrokeShape="RoundRectangle 16" Padding="18"
                    StrokeThickness="1" Stroke="{StaticResource Gray200}">
                <VerticalStackLayout Spacing="10">
                    <!-- صورة المنتج (أو رمز تعبيري بديل) عند توفّر النتيجة -->
                    <Border IsVisible="{Binding Result.Found}" HeightRequest="160" WidthRequest="160"
                            HorizontalOptions="Center" StrokeThickness="0" BackgroundColor="{StaticResource Gray100}"
                            StrokeShape="RoundRectangle 14" Padding="0">
                        <Grid>
                            <Image Source="{Binding Result.FullImageUrl}" Aspect="AspectFit" Margin="8"
                                   IsVisible="{Binding Result.HasImage}" />
                            <Label Text="{Binding Result.Glyph}" FontSize="72"
                                   HorizontalOptions="Center" VerticalOptions="Center"
                                   IsVisible="{Binding Result.HasImage, Converter={StaticResource Invert}}" />
                        </Grid>
                    </Border>

                    <Label Text="{Binding Result.NameAr}" FontSize="18" FontAttributes="Bold"
                           IsVisible="{Binding Result.Found}" />
                    <HorizontalStackLayout Spacing="8" IsVisible="{Binding Result.Found}">
                        <Label Text="{svc:Translate Key=scan.ourprice}" FontSize="14" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                        <Label Text="{Binding Result.OurPriceInclTax, Converter={StaticResource Price}}"
                               FontSize="26" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                        <Label Text="{svc:Translate Key=common.currency}" VerticalOptions="Center" TextColor="{StaticResource Gray500}" />
                    </HorizontalStackLayout>

                    <Button Text="{svc:Translate Key=catalog.add}" Command="{Binding AddResultToCartCommand}"
                            IsVisible="{Binding CanAddResult}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" />

                    <Label Text="{svc:Translate Key=scan.notfound}" FontSize="16" TextColor="{StaticResource Gray500}"
                           IsVisible="{Binding Result.Found, Converter={StaticResource Invert}}" />
                </VerticalStackLayout>
            </Border>

            <Label Text="{Binding ErrorMessage}" TextColor="Red" IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNull}}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
