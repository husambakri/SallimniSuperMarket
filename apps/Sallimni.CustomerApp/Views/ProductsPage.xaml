<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.CustomerApp.Models"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             x:Class="Sallimni.CustomerApp.Views.ProductsPage"
             x:Name="Page"
             x:DataType="vm:ProductsViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{Binding Title}">

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
        <CollectionView ItemsSource="{Binding Products}" Margin="10">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.EmptyView>
                <Label Text="{svc:Translate Key=common.loading}" HorizontalOptions="Center" Margin="0,40" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="m:ProductDto">
                    <!-- البطاقة بلا إطار (شفافة)؛ الصورة وحدها داخل صندوق بخلفية رماديّة. -->
                    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="3" BackgroundColor="Transparent">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenProductCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <!-- صندوق الصورة: خلفية فاتحة + حواف مدوّرة -->
                        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="{StaticResource Gray100}"
                                StrokeShape="RoundRectangle 14" HeightRequest="140" Padding="12">
                            <Grid>
                                <Image Source="{Binding FullImageUrl}" Aspect="AspectFit" IsVisible="{Binding HasImage}"
                                       WidthRequest="110" HeightRequest="110"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                                <Label Text="{Binding Glyph}" FontSize="56" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding HasImage, Converter={StaticResource Invert}}" />
                                <Border IsVisible="{Binding HasSavings}" BackgroundColor="#FFF3C4" Padding="6,2"
                                        StrokeShape="RoundRectangle 8" StrokeThickness="0"
                                        HorizontalOptions="Start" VerticalOptions="Start">
                                    <Label Text="{Binding SavingsText}" FontSize="10" FontAttributes="Bold" TextColor="#9A6700" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- زرّ الإضافة متراكب على زاوية صندوق الصورة -->
                        <Button Grid.Row="0" Text="+" FontSize="22" FontAttributes="Bold"
                                WidthRequest="42" HeightRequest="42" Padding="0" CornerRadius="21"
                                BackgroundColor="{StaticResource Primary}" TextColor="White"
                                HorizontalOptions="End" VerticalOptions="End" Margin="6"
                                Clicked="OnAddTapped"
                                Command="{Binding Source={x:Reference Page}, Path=BindingContext.AddToCartCommand}"
                                CommandParameter="{Binding .}" />

                            <!-- الاسم: ارتفاع ثابت لسطرين -->
                            <Label Grid.Row="1" Text="{Binding NameAr}" FontSize="13.5" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}" MaxLines="2" LineBreakMode="TailTruncation"
                                   HeightRequest="38" VerticalTextAlignment="Start" />

                            <!-- الوحدة -->
                            <Label Grid.Row="2" Text="{Binding UnitSize}" FontSize="11" TextColor="{StaticResource Gray400}" />

                            <!-- السعر مثبّت أسفل البطاقة (Row 4 بعد الفاصل المرن Row 3) -->
                            <VerticalStackLayout Grid.Row="4" Spacing="0" VerticalOptions="End">
                                <HorizontalStackLayout Spacing="3">
                                    <Label Text="{Binding CheapestPriceInclTax, Converter={StaticResource Price}}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
                                    <Label Text="{svc:Translate Key=common.currency}" FontSize="11" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label IsVisible="{Binding HasSavings}" FontSize="11" TextColor="{StaticResource Gray400}"
                                       TextDecorations="Strikethrough"
                                       Text="{Binding RegularPriceInclTax, Converter={StaticResource Price}}" />
                            </VerticalStackLayout>
                        </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>
