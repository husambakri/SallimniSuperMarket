<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             x:Class="Sallimni.CustomerApp.Views.ProductDetailPage"
             x:DataType="vm:ProductDetailViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{Binding Product.NameAr}">

    <Grid RowDefinitions="*,Auto">
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="20" Spacing="14">

                <!-- صورة كبيرة (رمز) + شارة التوفير -->
                <Border BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 20" StrokeThickness="0" HeightRequest="220">
                    <Grid>
                        <Label Text="{Binding Glyph}" FontSize="120" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border IsVisible="{Binding HasSavings}" BackgroundColor="#FFF3C4" Padding="10,4"
                                StrokeShape="RoundRectangle 10" StrokeThickness="0" Margin="14"
                                HorizontalOptions="Start" VerticalOptions="Start">
                            <Label Text="{Binding SavingsText}" FontSize="13" FontAttributes="Bold" TextColor="#9A6700" />
                        </Border>
                    </Grid>
                </Border>

                <Label Text="{Binding Product.NameAr}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Gray900}" />
                <Label Text="{Binding Product.UnitSize}" FontSize="13" TextColor="{StaticResource Gray500}" />

                <!-- السعر -->
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <Label Text="{Binding Product.CheapestPriceInclTax, Converter={StaticResource Price}}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    <Label Text="{svc:Translate Key=common.currency}" FontSize="13" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                    <Label IsVisible="{Binding HasSavings}" Text="{Binding Product.RegularPriceInclTax, Converter={StaticResource Price}}"
                           FontSize="15" TextColor="{StaticResource Gray400}" TextDecorations="Strikethrough" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                <!-- الوصف -->
                <Label Text="{svc:Translate Key=detail.description}" FontSize="15" FontAttributes="Bold" />
                <Label Text="{Binding Product.Description}" FontSize="14" TextColor="{StaticResource Gray600}" LineHeight="1.4" />
            </VerticalStackLayout>
        </ScrollView>

        <!-- زرّ الإضافة الثابت -->
        <Border Grid.Row="1" Padding="16" StrokeThickness="0" BackgroundColor="{StaticResource Gray100}">
            <Button Text="{svc:Translate Key=detail.add}" Command="{Binding AddToCartCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="24" HeightRequest="52" FontAttributes="Bold" FontSize="16" />
        </Border>
    </Grid>
</ContentPage>
