<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             x:Class="Sallimni.CustomerApp.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.settings}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="{svc:Translate Key=settings.title}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />

            <!-- اللغة -->
            <VerticalStackLayout Spacing="8">
                <Label Text="{svc:Translate Key=settings.language}" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="10">
                    <Button Text="{svc:Translate Key=settings.arabic}" Command="{Binding SetArabicCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="20" Padding="20,6" />
                    <Button Text="{svc:Translate Key=settings.english}" Command="{Binding SetEnglishCommand}"
                            BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray900}" CornerRadius="20" Padding="20,6" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

            <!-- الحساب -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{svc:Translate Key=settings.customer}" FontAttributes="Bold" />
                <Label Text="{Binding CustomerName}" TextColor="{StaticResource Gray600}" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="{svc:Translate Key=settings.server}" FontAttributes="Bold" />
                <Label Text="{Binding ServerUrl}" TextColor="{StaticResource Gray600}" FontSize="12" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

            <!-- روابط قانونية (إلزامية للمتجرين) -->
            <VerticalStackLayout Spacing="6">
                <Label Text="{svc:Translate Key=settings.legal}" FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="16">
                    <Label Text="{svc:Translate Key=settings.privacy}" TextColor="{StaticResource Primary}" TextDecorations="Underline">
                        <Label.GestureRecognizers><TapGestureRecognizer Command="{Binding OpenPrivacyCommand}" /></Label.GestureRecognizers>
                    </Label>
                    <Label Text="{svc:Translate Key=settings.terms}" TextColor="{StaticResource Primary}" TextDecorations="Underline">
                        <Label.GestureRecognizers><TapGestureRecognizer Command="{Binding OpenTermsCommand}" /></Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

            <!-- حذف الحساب (متطلب المتجرين) -->
            <Button Text="{svc:Translate Key=settings.delete}" Command="{Binding DeleteAccountCommand}"
                    BackgroundColor="#D32F2F" TextColor="White" CornerRadius="22" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
