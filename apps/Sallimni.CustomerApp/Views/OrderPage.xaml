<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CustomerApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.CustomerApp.Models"
             xmlns:svc="clr-namespace:Sallimni.CustomerApp.Services"
             x:Class="Sallimni.CustomerApp.Views.OrderPage"
             x:DataType="vm:OrderViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=order.title}">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="✅ " FontSize="14">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="✅  " />
                        <Span Text="{svc:Translate Key=order.placed}" FontAttributes="Bold" FontSize="20" />
                    </FormattedString>
                </Label.FormattedText>
            </Label>

            <!-- ETA باللون البرتقالي (هوية الزبون، قسم 6.3) -->
            <Border BackgroundColor="{StaticResource Primary}" Padding="16" StrokeShape="RoundRectangle 16" StrokeThickness="0">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{svc:Translate Key=order.eta}" TextColor="#FFE0B2" FontSize="13" />
                    <Label Text="{Binding EtaText}" TextColor="White" FontSize="24" FontAttributes="Bold" />
                    <Label Text="{svc:Translate Key=order.wave_note}" TextColor="#FFE0B2" FontSize="12" />
                </VerticalStackLayout>
            </Border>

            <!-- الحالة -->
            <Grid ColumnDefinitions="Auto,*">
                <Label Text="{svc:Translate Key=order.status}" FontSize="14" TextColor="{StaticResource Gray500}" />
                <Label Grid.Column="1" Text="{Binding StatusText}" HorizontalTextAlignment="End" FontAttributes="Bold" FontSize="14" TextColor="{StaticResource PrimaryDark}" />
            </Grid>

            <Label Text="{svc:Translate Key=order.split_note}" FontSize="12" TextColor="{StaticResource Gray500}" />

            <!-- الطلبات الفرعية لكل تاجر -->
            <CollectionView ItemsSource="{Binding Order.SubOrders}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:SubOrderDto">
                        <Border Margin="0,5" Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🏪" FontSize="15" />
                                    <Label Text="{Binding MerchantName}" FontAttributes="Bold" FontSize="16" TextColor="{StaticResource PrimaryDark}" />
                                </HorizontalStackLayout>

                                <CollectionView ItemsSource="{Binding Items}">
                                    <CollectionView.ItemTemplate>
                                        <DataTemplate x:DataType="m:OrderItemDto">
                                            <Grid ColumnDefinitions="*,Auto,Auto" Padding="0,3" ColumnSpacing="6">
                                                <Label Grid.Column="0" Text="{Binding Name}" FontSize="14" />
                                                <Label Grid.Column="1" Text="{Binding Quantity, StringFormat='×{0}'}" FontSize="13" TextColor="{StaticResource Gray500}" />
                                                <Label Grid.Column="2" Text="{Binding UnitPriceInclTax, Converter={StaticResource Price}}" FontSize="14" FontAttributes="Bold" />
                                            </Grid>
                                        </DataTemplate>
                                    </CollectionView.ItemTemplate>
                                </CollectionView>

                                <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Text="{svc:Translate Key=cart.total}" FontSize="13" TextColor="{StaticResource Gray500}" />
                                    <Label Grid.Column="1" Text="{Binding SubtotalInclTax, Converter={StaticResource Price}}" FontAttributes="Bold" FontSize="15" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- غير المتوفر -->
            <Border IsVisible="{Binding HasUnfulfilled}" Padding="12" StrokeShape="RoundRectangle 12"
                    BackgroundColor="#FFF3E0" StrokeThickness="0">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{svc:Translate Key=order.unfulfilled}" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
                    <CollectionView ItemsSource="{Binding Order.Unfulfilled}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="m:UnfulfilledDto">
                                <Label Text="{Binding Reason}" FontSize="12" TextColor="{StaticResource Gray600}" />
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <!-- الإجمالي الكلّي -->
            <Grid ColumnDefinitions="*,Auto" Padding="4,8">
                <Label Text="{svc:Translate Key=cart.total}" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="4">
                    <Label Text="{Binding Order.GrandTotal, Converter={StaticResource Price}}" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    <Label Text="{svc:Translate Key=common.currency}" VerticalOptions="Center" TextColor="{StaticResource Gray500}" />
                </HorizontalStackLayout>
            </Grid>

            <Button Text="{svc:Translate Key=order.track}" Command="{Binding RefreshCommand}"
                    BackgroundColor="{StaticResource Gray100}" TextColor="{StaticResource Gray900}" CornerRadius="22" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
