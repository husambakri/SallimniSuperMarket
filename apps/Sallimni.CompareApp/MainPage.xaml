<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CompareApp.ViewModels"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="Sallimni.CompareApp.MainPage"
             x:DataType="vm:CompareViewModel"
             FlowDirection="RightToLeft"
             BackgroundColor="{StaticResource PageBg}"
             Title="مقارنة الأسعار">

    <ScrollView>
        <VerticalStackLayout Padding="18,16,18,28" Spacing="18">

            <!-- الترويسة -->
            <VerticalStackLayout Spacing="2">
                <Label Text="مقارنة الأسعار" FontSize="23" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                <Label Text="امسح الباركود واعرف أرخص سعر فوراً" FontSize="13" TextColor="{StaticResource Gray500}" />
            </VerticalStackLayout>

            <!-- معاينة الكاميرا الحيّة (أثناء المسح) -->
            <Border IsVisible="{Binding IsScanning}" StrokeShape="RoundRectangle 20" StrokeThickness="2"
                    Stroke="{StaticResource Accent}" HeightRequest="280" Padding="0"
                    BackgroundColor="{StaticResource Gray950}">
                <Grid>
                    <scanner:CameraView x:Name="Reader"
                            CameraEnabled="{Binding IsScanning}"
                            VibrationOnDetected="True"
                            ViewfinderMode="True"
                            CaptureQuality="Medium"
                            BarcodeSymbologies="All"
                            OnDetectionFinished="OnDetectionFinished" />
                    <!-- تلميح المسح -->
                    <Border VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,14"
                            BackgroundColor="#CC000000" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,7">
                        <Label Text="وجّه الكاميرا نحو الباركود" FontSize="12" TextColor="White" />
                    </Border>
                </Grid>
            </Border>

            <!-- الفعل الأساسي: امسح بالكاميرا (الهاتف فقط) -->
            <Button Text="📷  امسح الباركود" Command="{Binding ToggleScanCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    CornerRadius="27" HeightRequest="54" FontSize="16" FontAttributes="Bold"
                    Padding="12,0" LineBreakMode="NoWrap">
                <Button.IsVisible>
                    <OnPlatform x:TypeArguments="x:Boolean">
                        <On Platform="Android,iOS" Value="True" />
                        <On Platform="WinUI" Value="False" />
                    </OnPlatform>
                </Button.IsVisible>
            </Button>

            <!-- إدخال يدوي أنيق (حقل + قارن داخل حبّة واحدة) -->
            <Border Stroke="{StaticResource Gray200}" StrokeThickness="1" StrokeShape="RoundRectangle 27"
                    BackgroundColor="{StaticResource Surface}" Padding="6,5">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="🔎" FontSize="16" Margin="10,0,2,0" VerticalOptions="Center" />
                    <Entry Grid.Column="1" Placeholder="أدخل الباركود يدويًا" Text="{Binding Barcode}"
                           Keyboard="Numeric" FontSize="16" BackgroundColor="Transparent" VerticalOptions="Center" />
                    <Button Grid.Column="2" Text="قارن" Command="{Binding CompareCommand}"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="21" HeightRequest="42" Padding="20,0" FontAttributes="Bold" />
                </Grid>
            </Border>

            <!-- جارٍ البحث -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}" Spacing="8" Margin="0,12">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
                <Label Text="نبحث عن أرخص سعر…" FontSize="13" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- بطاقة النتيجة الموحّدة: صورة كبيرة → سعر → توفير → المتجر -->
            <Border IsVisible="{Binding HasProduct}" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="16">
                <VerticalStackLayout Spacing="14">

                    <!-- صورة المنتج المربّعة: خلفية بيضاء بحدّ خفيف لتندمج صور المنتجات (الارتفاع = العرض) -->
                    <Border x:Name="ImageFrame" SizeChanged="OnImageFrameSizeChanged"
                            Stroke="{StaticResource Gray100}" StrokeThickness="1" Padding="0" HorizontalOptions="Fill"
                            BackgroundColor="{StaticResource Surface}" StrokeShape="RoundRectangle 16">
                        <Grid>
                            <Label Text="🛒" FontSize="66" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Image Source="{Binding ProductImageUrl}" Aspect="AspectFit" Margin="14"
                                   IsVisible="{Binding ProductHasImage}" />
                        </Grid>
                    </Border>

                    <!-- اسم المنتج -->
                    <Label Text="{Binding ProductName}" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource Gray900}" HorizontalTextAlignment="Center"
                           MaxLines="2" LineBreakMode="TailTruncation" />

                    <!-- كتلة السعر + التوفير -->
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="أرخص سعر" FontSize="12" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                        <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="{Binding CheapestPriceText}" FontSize="40" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="د.أ" FontSize="16" TextColor="{StaticResource Gray500}" VerticalOptions="End" Margin="0,0,0,9" />
                        </HorizontalStackLayout>
                        <!-- حبّة التوفير (خضراء = إشارة الربح) -->
                        <Border IsVisible="{Binding HasSavings}" BackgroundColor="{StaticResource Accent}"
                                StrokeThickness="0" StrokeShape="RoundRectangle 15" Padding="14,6" HorizontalOptions="Center">
                            <Label Text="{Binding SavingsText}" FontSize="13" FontAttributes="Bold" TextColor="White" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- فاصل -->
                    <BoxView HeightRequest="1" Color="{StaticResource Gray100}" Margin="0,2" />

                    <!-- المتجر الأرخص + التوفّر -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                        <Border Grid.Column="0" WidthRequest="46" HeightRequest="46" StrokeThickness="0"
                                BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 12" Padding="0">
                            <Label Text="🏪" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{Binding StoreName}" FontSize="15" FontAttributes="Bold"
                                   TextColor="{StaticResource Gray900}" MaxLines="1" LineBreakMode="TailTruncation" />
                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" VerticalOptions="Center"
                                         Color="{StaticResource Gray300}">
                                    <BoxView.Triggers>
                                        <DataTrigger TargetType="BoxView" Binding="{Binding InStock}" Value="True">
                                            <Setter Property="Color" Value="{StaticResource Accent}" />
                                        </DataTrigger>
                                    </BoxView.Triggers>
                                </BoxView>
                                <Label Text="{Binding AvailabilityText}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- حالة لا نتيجة / خطأ -->
            <Border IsVisible="{Binding HasError}" StrokeShape="RoundRectangle 18" StrokeThickness="1"
                    Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="20">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🔍" FontSize="34" HorizontalOptions="Center" />
                    <Label Text="{Binding ErrorMessage}" FontSize="14" TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
