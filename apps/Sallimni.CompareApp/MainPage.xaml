<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CompareApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.CompareApp.Models"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="Sallimni.CompareApp.MainPage"
             x:DataType="vm:CompareViewModel"
             FlowDirection="RightToLeft"
             BackgroundColor="{StaticResource PageBg}"
             Title="مقارنة الأسعار">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0" Text="مقارنة الأسعار" FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="🔍" FontSize="20" VerticalOptions="Center" />
            </Grid>

            <!-- معاينة الكاميرا الحيّة (أثناء المسح) -->
            <Border IsVisible="{Binding IsScanning}" StrokeShape="RoundRectangle 16" StrokeThickness="2"
                    Stroke="{StaticResource Accent}" HeightRequest="260" Padding="0"
                    BackgroundColor="{StaticResource PrimaryDark}">
                <scanner:CameraView x:Name="Reader"
                        CameraEnabled="{Binding IsScanning}"
                        VibrationOnDetected="True"
                        ViewfinderMode="True"
                        CaptureQuality="Medium"
                        BarcodeSymbologies="All"
                        OnDetectionFinished="OnDetectionFinished" />
            </Border>

            <!-- زرّ مسح الكاميرا (الهاتف فقط) -->
            <Button Text="📷  امسح بالكاميرا" Command="{Binding ToggleScanCommand}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    CornerRadius="22" HeightRequest="46" FontAttributes="Bold">
                <Button.IsVisible>
                    <OnPlatform x:TypeArguments="x:Boolean">
                        <On Platform="Android,iOS" Value="True" />
                        <On Platform="WinUI" Value="False" />
                    </OnPlatform>
                </Button.IsVisible>
            </Button>

            <!-- إدخال يدوي + قارن -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <Entry Grid.Column="0" Placeholder="أدخل الباركود يدويًا" Text="{Binding Barcode}"
                       Keyboard="Numeric" FontSize="16" />
                <Button Grid.Column="1" Text="قارن" Command="{Binding CompareCommand}"
                        BackgroundColor="{StaticResource PrimaryDark}" TextColor="White"
                        CornerRadius="22" WidthRequest="84" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource Primary}" />

            <!-- بطاقة المنتج: الصورة تملأ الإطار حافة لحافة (بلا padding) -->
            <Border IsVisible="{Binding HasProduct}" StrokeShape="RoundRectangle 16" StrokeThickness="1"
                    Stroke="{StaticResource Gray200}" BackgroundColor="{StaticResource Surface}" Padding="12">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border Grid.Column="0" WidthRequest="76" HeightRequest="76" StrokeThickness="0"
                            BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 13" Padding="0">
                        <Grid>
                            <!-- أيقونة بديلة ريثما تُحمَّل الصورة (placeholder) -->
                            <Label Text="🛒" FontSize="36" HorizontalOptions="Center" VerticalOptions="Center" />
                            <!-- تحميل كسول: الصورة تُجلب لا-تزامنيًّا وتُخزَّن مؤقّتًا (افتراضي MAUI) -->
                            <Image x:Name="ProductImg" Source="{Binding ProductImageUrl}" Aspect="AspectFill"
                                   IsVisible="{Binding ProductHasImage}" />
                            <!-- مؤشّر أثناء التحميل -->
                            <ActivityIndicator Color="{StaticResource Primary}" HeightRequest="24"
                                               HorizontalOptions="Center" VerticalOptions="Center"
                                               IsRunning="{Binding Source={x:Reference ProductImg}, Path=IsLoading}"
                                               IsVisible="{Binding Source={x:Reference ProductImg}, Path=IsLoading}" />
                        </Grid>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                        <Label Text="{Binding ProductName}" FontSize="15" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" MaxLines="2" LineBreakMode="TailTruncation" />
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="أرخص سعر" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                            <Label Text="{Binding CheapestPriceText}" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                            <Label Text="د.أ" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- ترويسة المقارنة -->
            <Grid ColumnDefinitions="*,Auto" IsVisible="{Binding HasCompared}" Margin="2,4,2,0">
                <Label Grid.Column="0" Text="{Binding ResultCount, StringFormat='في {0} متجر'}"
                       FontSize="14" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center" />
                <Label Grid.Column="1" Text="الأرخص أولاً" FontSize="11" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
            </Grid>

            <!-- قائمة المتاجر -->
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Results}" Spacing="0" IsVisible="{Binding HasCompared}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:LiveScanDto">
                        <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="{StaticResource Gray200}"
                                Padding="10" Margin="0,0,0,8" Opacity="{Binding RowOpacity}">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding IsCheapest}" Value="True">
                                    <Setter Property="Stroke" Value="{StaticResource Primary}" />
                                    <Setter Property="StrokeThickness" Value="2" />
                                </DataTrigger>
                            </Border.Triggers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <!-- أيقونة المتجر فقط (بلا تحميل صورة لكل صفّ — صورة المنتج تكفي بالأعلى) -->
                                <Border Grid.Column="0" WidthRequest="52" HeightRequest="52" StrokeThickness="0"
                                        BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 11" Padding="0">
                                    <Label Text="{Binding Glyph}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding Store}" FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource Gray900}" MaxLines="1" VerticalOptions="Center" />
                                        <Border IsVisible="{Binding IsCheapest}" BackgroundColor="{StaticResource Primary}"
                                                StrokeThickness="0" StrokeShape="RoundRectangle 8" Padding="6,1" VerticalOptions="Center">
                                            <Label Text="الأرخص" FontSize="10" TextColor="White" />
                                        </Border>
                                    </HorizontalStackLayout>
                                    <Label Text="{Binding AvailabilityText}" FontSize="11" TextColor="{StaticResource Gray400}" MaxLines="1" />
                                    <Label Text="{Binding Note}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource Primary}"
                                           IsVisible="{Binding HasNote}" MaxLines="1" />
                                </VerticalStackLayout>
                                <HorizontalStackLayout Grid.Column="2" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding PriceText}" FontSize="17" FontAttributes="Bold" TextColor="{StaticResource PrimaryDark}" />
                                    <Label Text="د.أ" FontSize="11" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Label Text="{Binding ErrorMessage}" TextColor="#A32D2D" FontSize="13"
                   IsVisible="{Binding HasError}" HorizontalOptions="Center" Margin="0,4" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
