<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.CompareApp.ViewModels"
             xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="Sallimni.CompareApp.MainPage"
             x:DataType="vm:CompareViewModel"
             FlowDirection="RightToLeft"
             BackgroundColor="{StaticResource PageBg}"
             Title="مقارنة الأسعار">

    <!-- صفحة واحدة بلا تمرير: ترويسة + أزرار ثابتة، والبطاقة تملأ ما تبقّى -->
    <Grid Padding="18,14,18,18" RowSpacing="12" RowDefinitions="Auto,Auto,Auto,*">

        <!-- الترويسة -->
        <VerticalStackLayout Grid.Row="0" Spacing="1">
            <Label Text="مقارنة الأسعار" FontSize="22" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
            <Label Text="امسح الباركود واعرف أرخص سعر فورًا" FontSize="12.5" TextColor="{StaticResource Gray500}" />
        </VerticalStackLayout>

        <!-- الفعل الأساسي: امسح بالكاميرا (الهاتف فقط) -->
        <Button Grid.Row="1" Text="📷  امسح الباركود" Command="{Binding ToggleScanCommand}"
                BackgroundColor="{StaticResource Primary}" TextColor="White"
                CornerRadius="26" HeightRequest="52" FontSize="16" FontAttributes="Bold"
                Padding="12,0" LineBreakMode="NoWrap">
            <Button.IsVisible>
                <OnPlatform x:TypeArguments="x:Boolean">
                    <On Platform="Android,iOS" Value="True" />
                    <On Platform="WinUI" Value="False" />
                </OnPlatform>
            </Button.IsVisible>
        </Button>

        <!-- إدخال يدوي أنيق (حقل + قارن داخل حبّة واحدة) -->
        <Border Grid.Row="2" Stroke="{StaticResource Gray200}" StrokeThickness="1" StrokeShape="RoundRectangle 26"
                BackgroundColor="{StaticResource Surface}" Padding="6,5">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="4" VerticalOptions="Center">
                <Label Grid.Column="0" Text="🔎" FontSize="16" Margin="10,0,2,0" VerticalOptions="Center" />
                <Entry Grid.Column="1" Placeholder="أدخل الباركود يدويًا" Text="{Binding Barcode}"
                       Keyboard="Numeric" FontSize="16" BackgroundColor="Transparent" VerticalOptions="Center" />
                <Button Grid.Column="2" Text="قارن" Command="{Binding CompareCommand}"
                        BackgroundColor="{StaticResource Primary}" TextColor="White"
                        CornerRadius="20" HeightRequest="40" Padding="20,0" FontAttributes="Bold" />
            </Grid>
        </Border>

        <!-- المساحة المرنة: تلميح فارغ / كاميرا / نتيجة / خطأ — كلّها في خليّة واحدة -->
        <Grid Grid.Row="3">

            <!-- تلميح (يظهر حين لا شيء فوقه؛ تغطّيه البطاقة/الكاميرا) -->
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                <Label Text="🛍️" FontSize="60" HorizontalOptions="Center" Opacity="0.5" />
                <Label Text="امسح باركود المنتج أو أدخله للبحث عن أرخص سعر"
                       FontSize="13.5" TextColor="{StaticResource Gray400}"
                       HorizontalTextAlignment="Center" MaxLines="2" />
            </VerticalStackLayout>

            <!-- معاينة الكاميرا الحيّة (حجم مقيّد، لا يملأ الشاشة) -->
            <Border IsVisible="{Binding IsScanning}" HeightRequest="300" VerticalOptions="Center"
                    StrokeShape="RoundRectangle 20" StrokeThickness="2"
                    Stroke="{StaticResource Accent}" Padding="0" BackgroundColor="{StaticResource Gray950}">
                <Grid>
                    <scanner:CameraView x:Name="Reader"
                            CameraEnabled="{Binding IsScanning}"
                            VibrationOnDetected="True"
                            ViewfinderMode="True"
                            CaptureQuality="Medium"
                            BarcodeSymbologies="All"
                            OnDetectionFinished="OnDetectionFinished" />
                    <Border VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,14"
                            BackgroundColor="#CC000000" StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="14,7">
                        <Label Text="وجّه الكاميرا نحو الباركود" FontSize="12" TextColor="White" />
                    </Border>
                </Grid>
            </Border>

            <!-- بطاقة النتيجة الموحّدة: صورة تملأ الأعلى، والتفاصيل أسفلها -->
            <Border IsVisible="{Binding HasProduct}" StrokeShape="RoundRectangle 22" StrokeThickness="1"
                    Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="16">
                <Grid RowDefinitions="*,Auto" RowSpacing="14">

                    <!-- صورة المنتج تملأ المساحة المتاحة (خلفية بيضاء لتندمج) -->
                    <Border Grid.Row="0" Stroke="{StaticResource Gray100}" StrokeThickness="1" Padding="0"
                            BackgroundColor="{StaticResource Surface}" StrokeShape="RoundRectangle 16">
                        <Grid>
                            <Label Text="🛒" FontSize="62" HorizontalOptions="Center" VerticalOptions="Center" />
                            <Image Source="{Binding ProductImageUrl}" Aspect="AspectFit" Margin="14"
                                   IsVisible="{Binding ProductHasImage}" />
                        </Grid>
                    </Border>

                    <!-- التفاصيل: الاسم + السعر + التوفير + المتجر -->
                    <VerticalStackLayout Grid.Row="1" Spacing="10">
                        <Label Text="{Binding ProductName}" FontSize="17" FontAttributes="Bold"
                               TextColor="{StaticResource Gray900}" HorizontalTextAlignment="Center"
                               MaxLines="1" LineBreakMode="TailTruncation" />

                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="أرخص سعر" FontSize="11.5" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
                            <HorizontalStackLayout Spacing="5" HorizontalOptions="Center">
                                <Label Text="{Binding CheapestPriceText}" FontSize="36" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                <Label Text="د.أ" FontSize="15" TextColor="{StaticResource Gray500}" VerticalOptions="End" Margin="0,0,0,8" />
                            </HorizontalStackLayout>
                            <Border IsVisible="{Binding HasSavings}" BackgroundColor="{StaticResource Accent}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 14" Padding="13,5" HorizontalOptions="Center">
                                <Label Text="{Binding SavingsText}" FontSize="12.5" FontAttributes="Bold" TextColor="White" />
                            </Border>
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="{StaticResource Gray100}" />

                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12" VerticalOptions="Center">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeThickness="0"
                                    BackgroundColor="{StaticResource Gray100}" StrokeShape="RoundRectangle 12" Padding="0">
                                <Label Text="🏪" FontSize="21" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding StoreName}" FontSize="15" FontAttributes="Bold"
                                       TextColor="{StaticResource Gray900}" MaxLines="1" LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                    <BoxView WidthRequest="8" HeightRequest="8" CornerRadius="4" VerticalOptions="Center"
                                             Color="{StaticResource Gray300}">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding InStock}" Value="True">
                                                <Setter Property="Color" Value="{StaticResource Accent}" />
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                    <Label Text="{Binding AvailabilityText}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                    <Label Text="•" FontSize="12" TextColor="{StaticResource Gray300}" VerticalOptions="Center"
                                           IsVisible="{Binding HasDistance}" />
                                    <Label Text="{Binding DistanceText}" FontSize="12" FontAttributes="Bold"
                                           TextColor="{StaticResource Accent}" VerticalOptions="Center"
                                           IsVisible="{Binding HasDistance}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- حالة لا نتيجة / خطأ -->
            <Border IsVisible="{Binding HasError}" VerticalOptions="Center" StrokeShape="RoundRectangle 18" StrokeThickness="1"
                    Stroke="{StaticResource Gray100}" BackgroundColor="{StaticResource Surface}" Padding="20">
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label Text="🔍" FontSize="34" HorizontalOptions="Center" />
                    <Label Text="{Binding ErrorMessage}" FontSize="14" TextColor="{StaticResource Gray600}"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Border>

            <!-- جارٍ البحث -->
            <VerticalStackLayout IsVisible="{Binding IsBusy}" VerticalOptions="Center" Spacing="8">
                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{StaticResource Primary}" />
                <Label Text="نبحث عن أرخص سعر…" FontSize="13" TextColor="{StaticResource Gray500}" HorizontalOptions="Center" />
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>
