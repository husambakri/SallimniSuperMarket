<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.DriverApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.DriverApp.Models"
             xmlns:svc="clr-namespace:Sallimni.DriverApp.Services"
             x:Class="Sallimni.DriverApp.Views.TasksPage"
             x:Name="Page"
             x:DataType="vm:TasksViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.tasks}">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,12" StrokeThickness="0">
            <Label Text="{svc:Translate Key=tasks.title}" FontSize="18" FontAttributes="Bold" TextColor="White" />
        </Border>

        <Label Grid.Row="1" IsVisible="{Binding IsEmpty}" Text="{svc:Translate Key=tasks.empty}"
               HorizontalOptions="Center" VerticalOptions="Center" TextColor="{StaticResource Gray400}" />

        <RefreshView Grid.Row="1" IsRefreshing="{Binding IsBusy}" Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Tasks}" Margin="10">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="m:DriverTaskDto">
                        <Border Margin="0,5" Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference Page}, Path=BindingContext.OpenTaskCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Label Grid.Column="0" Text="📦" FontSize="20" IsVisible="{Binding IsCollection}" />
                                    <Label Grid.Column="0" Text="🚚" FontSize="20" IsVisible="{Binding IsDistribution}" />
                                    <Label Grid.Column="1" Margin="8,0,0,0" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"
                                           Text="{svc:Translate Key=tasks.collection}" IsVisible="{Binding IsCollection}" />
                                    <Label Grid.Column="1" Margin="8,0,0,0" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource PrimaryDark}" VerticalOptions="Center"
                                           Text="{svc:Translate Key=tasks.distribution}" IsVisible="{Binding IsDistribution}" />
                                    <Border Grid.Column="2" BackgroundColor="{StaticResource Secondary}" Padding="8,3" StrokeShape="RoundRectangle 10" StrokeThickness="0">
                                        <Label Text="{Binding Status, Converter={StaticResource TaskStatus}}" FontSize="12" TextColor="{StaticResource PrimaryDark}" />
                                    </Border>
                                </Grid>
                                <Label FontSize="12" TextColor="{StaticResource Gray500}">
                                    <Label.FormattedText><FormattedString>
                                        <Span Text="{Binding StopCount}" /><Span Text=" " /><Span Text="{svc:Translate Key=tasks.stops}" />
                                    </FormattedString></Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
