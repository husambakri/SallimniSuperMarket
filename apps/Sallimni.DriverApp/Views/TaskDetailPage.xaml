<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Sallimni.DriverApp.ViewModels"
             xmlns:m="clr-namespace:Sallimni.DriverApp.Models"
             xmlns:svc="clr-namespace:Sallimni.DriverApp.Services"
             x:Class="Sallimni.DriverApp.Views.TaskDetailPage"
             x:Name="Page"
             x:DataType="vm:TaskDetailViewModel"
             FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
             Title="{svc:Translate Key=tab.tasks}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ترويسة المهمة -->
        <Border Grid.Row="0" BackgroundColor="{StaticResource Primary}" Padding="16,12" StrokeThickness="0">
            <VerticalStackLayout Spacing="4">
                <Label FontSize="17" FontAttributes="Bold" TextColor="White"
                       Text="{svc:Translate Key=tasks.collection}" IsVisible="{Binding Task.IsCollection}" />
                <Label FontSize="17" FontAttributes="Bold" TextColor="White"
                       Text="{svc:Translate Key=tasks.distribution}" IsVisible="{Binding Task.IsDistribution}" />
                <Label FontSize="13" TextColor="{StaticResource Secondary}">
                    <Label.FormattedText><FormattedString>
                        <Span Text="{svc:Translate Key=tasks.status}" /><Span Text=": " />
                        <Span Text="{Binding Task.Status, Converter={StaticResource TaskStatus}}" />
                    </FormattedString></Label.FormattedText>
                </Label>
            </VerticalStackLayout>
        </Border>

        <!-- المحطّات -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="12" Spacing="8" BindableLayout.ItemsSource="{Binding Stops}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="m:DriverStopDto">
                        <Border Padding="14" StrokeShape="RoundRectangle 14" StrokeThickness="1" Stroke="{StaticResource Gray200}">
                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Label Grid.Column="0" Text="{Binding Sequence, StringFormat='{0}.'}" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource Primary}" />
                                    <Label Grid.Column="1" Margin="6,0,0,0" Text="{Binding Label}" FontSize="15" FontAttributes="Bold" VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{svc:Translate Key=detail.done}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Tertiary}" VerticalOptions="Center"
                                           IsVisible="{Binding IsCompleted}" />
                                </Grid>

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label Grid.Column="0" FontSize="12" TextColor="{StaticResource Gray500}">
                                        <Label.FormattedText><FormattedString>
                                            <Span Text="{Binding ItemCount}" /><Span Text=" " /><Span Text="{svc:Translate Key=detail.items}" />
                                        </FormattedString></Label.FormattedText>
                                    </Label>
                                    <Label Grid.Column="1" FontSize="12" FontAttributes="Bold" TextColor="{StaticResource Primary}" IsVisible="{Binding HasEta}">
                                        <Label.FormattedText><FormattedString>
                                            <Span Text="🕒 " /><Span Text="{svc:Translate Key=detail.eta}" /><Span Text=" " /><Span Text="{Binding EtaText}" />
                                        </FormattedString></Label.FormattedText>
                                    </Label>
                                </Grid>

                                <!-- تحصيل COD (للتوزيع) -->
                                <HorizontalStackLayout Spacing="6" IsVisible="{Binding CodAmount, Converter={StaticResource NotNull}}">
                                    <Label Text="{svc:Translate Key=detail.cod}" FontSize="13" TextColor="{StaticResource Gray500}" />
                                    <Label Text="{Binding CodAmount, Converter={StaticResource Price}}" FontSize="16" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                                    <Label Text="{svc:Translate Key=common.currency}" FontSize="12" TextColor="{StaticResource Gray500}" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <!-- زرّ الاستلام (تجميع) أو التسليم (توزيع) -->
                                <Button Text="{svc:Translate Key=detail.pickup}"
                                        IsVisible="{Binding IsPending}"
                                        BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="18" Padding="16,6" FontSize="13"
                                        Command="{Binding Source={x:Reference Page}, Path=BindingContext.ScanCommand}"
                                        CommandParameter="{Binding .}">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding Source={x:Reference Page}, Path=BindingContext.Task.IsDistribution}" Value="True">
                                            <Setter Property="Text" Value="{svc:Translate Key=detail.deliver}" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>

        <!-- أزرار بدء/إنهاء المهمة + الأخطاء -->
        <VerticalStackLayout Grid.Row="2" Padding="14" Spacing="6" BackgroundColor="{StaticResource Gray100}">
            <Label Text="{Binding ErrorMessage}" TextColor="Red" FontSize="12" IsVisible="{Binding ErrorMessage, Converter={StaticResource NotNull}}" />
            <Button Text="{svc:Translate Key=detail.start}" Command="{Binding StartCommand}" IsVisible="{Binding CanStart}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="22" HeightRequest="48" FontAttributes="Bold" />
            <Button Text="{svc:Translate Key=detail.complete}" Command="{Binding CompleteCommand}" IsVisible="{Binding CanComplete}"
                    BackgroundColor="{StaticResource Tertiary}" TextColor="White" CornerRadius="22" HeightRequest="48" FontAttributes="Bold" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
