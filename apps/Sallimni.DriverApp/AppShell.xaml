<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Sallimni.DriverApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Sallimni.DriverApp.Views"
    xmlns:svc="clr-namespace:Sallimni.DriverApp.Services"
    FlowDirection="{Binding IsRtl, Source={x:Static svc:LocalizationManager.Instance}, Converter={StaticResource FlowDir}}"
    Title="سلّمني سائق">

    <TabBar>
        <ShellContent Title="{svc:Translate Key=tab.tasks}"
                      ContentTemplate="{DataTemplate views:TasksPage}" Route="tasks" />
        <ShellContent Title="{svc:Translate Key=tab.settings}"
                      ContentTemplate="{DataTemplate views:SettingsPage}" Route="settings" />
    </TabBar>
</Shell>
